{
    "name": "harrygulliford/socialite-microsoft-graph",
    "description": "Microsoft Graph Provider for Laravel Socialite",
    "keywords": [
        "harrygulliford",
        "socialite-microsoft-graph"
    ],
    "homepage": "https://github.com/harrygulliford/socialite-microsoft-graph",
    "license": "MIT",
    "authors": [
        {
            "name": "Harry Gulliford"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "laravel/socialite": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "HarryGulliford\\SocialiteMicrosoftGraph\\": "src"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "HarryGulliford\\SocialiteMicrosoftGraph\\SocialiteMicrosoftGraphServiceProvider"
            ]
        }
    }
}
